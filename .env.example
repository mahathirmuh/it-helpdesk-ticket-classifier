# =====================================================================
# OpenAI API Configuration — IT Helpdesk Ticket Classifier
# Copy file ini ke .env dan isi dengan API key Anda.
# =====================================================================

# === Required ===
# API key yang sama dipakai untuk Embedding API DAN Chat/Responses API.
OPENAI_API_KEY=sk-proj-...

# === Embedding Model (Hybrid Fusion - default flow) ===
# Dipakai oleh OpenAIEmbedder untuk text -> 1536-dim vector.
# Endpoint: /embeddings. Hanya 1 model.
# Override via CLI: --embed-model text-embedding-3-large
OPENAI_EMBED_MODEL=text-embedding-3-small

# === Chat/LLM Models (Hybrid Voting - hanya saat --enable-voting) ===
# Dipakai untuk LLM prediksi independen di voting ensemble.
# Endpoint: /responses. Boleh multi-model (pisah koma) untuk ablation.
# Boleh dikosongkan kalau tidak pakai voting.
#
# Contoh model yang umum:
#   gpt-4.1-mini, gpt-4o-mini, gpt-4o, gpt-5-mini, gpt-5.4-mini
OPENAI_MODELS=gpt-4.1-mini
